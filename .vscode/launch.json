{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "ParserDriver",
      "request": "launch",
      "mainClass": "p4project.ParserDriver",
      "projectName": "p4-project"
    },
    {
      "name": "Debug ANTLR4 Grammar",
      "type": "antlr-debug",
      "request": "launch",
      "input": "${workspaceFolder}/sample-input.txt",
      "grammar": "${workspaceFolder}/src/main/antlr4/OurGrammar.g4",
      "startRule": "program",
      "printParseTree": true,
      "visualParseTree": true
    },
    {
      "name": "Run Parser Driver",
      "type": "java",
      "request": "launch",
      "mainClass": "p4project.ParserDriver",
      "projectName": "p4_project"
    }
  ]
}
